{
  "ci": {
    "collect": {
      "startServerCommand": "npm run start -- --port=3000",
      "url": [
        "http://localhost:3000"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "error",
          {
            "minScore": 0.85
          }
        ],
        "largest-contentful-paint": [
          "error",
          {
            "maxNumericValue": 3000
          }
        ],
        "total-blocking-time": [
          "error",
          {
            "maxNumericValue": 300
          }
        ],
        "cumulative-layout-shift": [
          "error",
          {
            "maxNumericValue": 0.1
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
